# Which backend to talk to: "local" or "production" (default: production).
# Overrides DEFAULT_API_ENV in lib/config.ts.
#   local      -> http://renmaitongadmin.test
#   production -> https://renmaitong-admin.astralweb.com.tw
API_ENV=production

# Optional: point at any base URL directly (wins over API_ENV). No trailing slash needed.
# API_BASE_URL=https://renmaitong-admin.astralweb.com.tw
